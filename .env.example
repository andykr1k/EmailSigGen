# SMTP Configuration for testing email signature sending
# If these are not configured, the app falls back to Ethereal Email sandbox.

# The SMTP host (e.g. smtp.gmail.com, smtp.mailtrap.io, etc.)
SMTP_HOST=

# The SMTP port (e.g. 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Your SMTP username / email address
SMTP_USER=

# Your SMTP password (or app-specific password)
SMTP_PASS=

# The sender email address (e.g. "My Signature Generator" <noreply@mydomain.com>)
SMTP_FROM=
